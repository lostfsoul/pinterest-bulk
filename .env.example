# App login password. Leave blank to disable the login screen.
APP_PASSWORD=

# Optional extra secret for signing the long-lived session cookie.
APP_SESSION_SECRET=

# Public domain used in exported Pinterest media URLs.
PUBLIC_BASE_URL=https://your-domain.com

# OpenAI SEO title generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20

# Image scraping tuning (safe defaults for small VPS)
# Page HTML fetch
SCRAPE_PAGE_TIMEOUT_SECONDS=20
SCRAPE_PAGE_RETRIES=1
SCRAPE_PAGES_CONCURRENCY=3

# Per-image metadata fetch
IMAGE_METADATA_TIMEOUT_SECONDS=12
IMAGE_METADATA_RETRIES=1
SCRAPE_METADATA_CONCURRENCY_PER_PAGE=4
